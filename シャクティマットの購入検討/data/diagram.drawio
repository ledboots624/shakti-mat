        <mxCell id="bg3" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f7fafc;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="790" y="80" width="360" height="460" as="geometry" />
        </mxCell>

        <!-- Section Headers -->
        <mxCell id="h1" value="1. 製品選び (モデル別)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4a5568;fontColor=#ffffff;fontSize=14;fontStyle=1;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="30" y="80" width="360" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h2" value="2. 使用体験と競合" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4a5568;fontColor=#ffffff;fontSize=14;fontStyle=1;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="410" y="80" width="360" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h3" value="3. 根拠と結論" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4a5568;fontColor=#ffffff;fontSize=14;fontStyle=1;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="790" y="80" width="360" height="40" as="geometry" />
        </mxCell>

        <!-- Column 1: Products -->
        <mxCell id="n11" value="【推奨】オリジナル (緑/橙)&#xa;標準強度・6000本&#xa;最もバランスが良い標準モデル" style="rounded=1;arcSize=8;shadow=1;fontSize=12;whiteSpace=wrap;html=1;fillColor=#f0fff4;strokeColor=#38a169;fontColor=#2d3748;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="60" y="150" width="300" height="80" as="geometry" />
        </mxCell>
        <mxCell id="n12" value="【注意】ライト (黄色)&#xa;低強度・8000本 (針多め=分散)&#xa;痛みに弱い・初心者・敏感肌向け" style="rounded=1;arcSize=8;shadow=1;fontSize=12;whiteSpace=wrap;html=1;fillColor=#fffff0;strokeColor=#d69e2e;fontColor=#2d3748;" vertex="1" parent="1">
          <mxGeometry x="60" y="260" width="300" height="80" as="geometry" />
        </mxCell>
        <mxCell id="n13" value="アドバンス (紫)&#xa;高強度・4000本 (針少なめ=集中)&#xa;刺激を求める上級者専用" style="rounded=1;arcSize=8;shadow=1;fontSize=12;whiteSpace=wrap;html=1;fillColor=#f7fafc;strokeColor=#a0aec0;fontColor=#2d3748;" vertex="1" parent="1">
          <mxGeometry x="60" y="370" width="300" height="80" as="geometry" />
        </mxCell>

        <!-- Column 2: Reality -->
        <mxCell id="n21" value="【警告】魔の5分間 (激痛)&#xa;使用開始直後は強い痛み&#xa;ここでの離脱・返品が多い" style="rounded=1;arcSize=8;shadow=1;fontSize=12;whiteSpace=wrap;html=1;fillColor=#fed7d7;strokeColor=#e53e3e;fontColor=#2d3748;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="440" y="150" width="300" height="80" as="geometry" />
        </mxCell>
        <mxCell id="n22" value="【核心】20分後の快感&#xa;エンドルフィン放出による&#xa;深いリラックスと温感・鎮痛" style="rounded=1;arcSize=8;shadow=1;fontSize=12;whiteSpace=wrap;html=1;fillColor=#f0fff4;strokeColor=#38a169;strokeWidth=3;fontColor=#2d3748;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="440" y="260" width="300" height="80" as="geometry" />
        </mxCell>
        <mxCell id="n23" value="格安競合品 (LifeZempra等)&#xa;安価だが針が鈍く耐久性が低い&#xa;倫理的製造プロセスではない" style="rounded=1;arcSize=8;shadow=1;fontSize=12;whiteSpace=wrap;html=1;fillColor=#f7fafc;strokeColor=#a0aec0;fontColor=#2d3748;" vertex="1" parent="1">
          <mxGeometry x="440" y="370" width="300" height="80" as="geometry" />
        </mxCell>

        <!-- Column 3: Evidence & Verdict -->
        <mxCell id="n31" value="エビデンス：腰痛・肩こり&#xa;運動療法との併用で&#xa;中程度の有効性が示唆される" style="rounded=1;arcSize=8;shadow=1;fontSize=12;whiteSpace=wrap;html=1;fillColor=#ebf4ff;strokeColor=#3182ce;fontColor=#2d3748;" vertex="1" parent="1">
          <mxGeometry x="820" y="150" width="300" height="80" as="geometry" />
        </mxCell>
        <mxCell id="n32" value="エビデンス：睡眠・疲労&#xa;客観データは限定的だが&#xa;主観的満足度は非常に高い" style="rounded=1;arcSize=8;shadow=1;fontSize=12;whiteSpace=wrap;html=1;fillColor=#ebf4ff;strokeColor=#3182ce;fontColor=#2d3748;" vertex="1" parent="1">
          <mxGeometry x="820" y="260" width="300" height="80" as="geometry" />
        </mxCell>
        <mxCell id="n33" value="【総合結論】条件付き「買い」&#xa;品質・倫理重視ならベストバイ&#xa;60日間の返品保証を活用せよ" style="rounded=1;arcSize=8;shadow=1;fontSize=12;whiteSpace=wrap;html=1;fillColor=#f0fff4;strokeColor=#38a169;strokeWidth=3;fontColor=#2d3748;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="820" y="370" width="300" height="80" as="geometry" />
        </mxCell>

        <!-- Footer -->
        <mxCell id="footer" value="Key Takeaway: 最初の痛みを乗り越える覚悟と、品質・倫理への投資意欲があるユーザーには強く推奨。" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#2d3748;fontColor=#ffffff;fontSize=16;fontStyle=1;strokeColor=none;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="0" y="580" width="1200" height="60" as="geometry" />
        </mxCell>

        <!-- Edges -->
        <mxCell id="e1" value="初心者はここから" style="edgeStyle=orthogonalEdgeStyle;curved=1;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4a5568;fontSize=11;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="n11" target="n21">
