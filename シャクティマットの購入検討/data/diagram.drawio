        <mxCell id="title" value="シャクティマット購入検討：全方位リサーチ結果" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#2d3748;fontColor=#ffffff;fontSize=22;fontStyle=1;strokeColor=none;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="60" as="geometry" />
